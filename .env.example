# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Token for PR comments (optional)
GITHUB_TOKEN=ghp_...

# Database URL for persistence (optional)
# DATABASE_URL=postgresql://user:pass@localhost:5432/build_triage

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Analysis settings
CONFIDENCE_THRESHOLD=0.7
MAX_LOG_LENGTH=50000
ANALYSIS_TIMEOUT=30

# Claude settings
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=2000
